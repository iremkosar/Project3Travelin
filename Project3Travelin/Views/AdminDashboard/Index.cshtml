@model Project3Travelin.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        .dash-title {
            font-size: 1.5rem;
            font-weight: 900;
            color: #0f172a;
            letter-spacing: -.03em;
        }

        .dash-sub {
            font-size: .875rem;
            color: #64748b;
            margin-top: 4px;
        }

        .dash-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.5rem;
            margin-top: 1.75rem;
        }

        @@media (max-width: 1199px) {
            .dash-grid {
                grid-template-columns: 1fr;
            }
        }

        .col-left {
            grid-column: 1 / 3;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .col-right {
            grid-column: 3 / 4;
        }

        @@media (max-width: 1199px) {
            .col-left {
                grid-column: 1;
            }

            .col-right {
                grid-column: 1;
            }
        }

        .panel {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .9rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
        }

            .panel-header h2 {
                font-size: 1rem;
                font-weight: 700;
                color: #0f172a;
                margin: 0;
            }

            .panel-header a {
                font-size: .8rem;
                font-weight: 600;
                color: #2563eb;
                text-decoration: none;
            }

                .panel-header a:hover {
                    text-decoration: underline;
                }

        .dash-table {
            width: 100%;
            border-collapse: collapse;
        }

            .dash-table thead th {
                background: #f8fafc;
                font-size: .7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .07em;
                color: #94a3b8;
                padding: .65rem 1.5rem;
                text-align: left;
                border-bottom: 1px solid #f1f5f9;
            }

            .dash-table tbody tr {
                border-bottom: 1px solid #f1f5f9;
                transition: background .1s;
            }

                .dash-table tbody tr:last-child {
                    border-bottom: none;
                }

                .dash-table tbody tr:hover {
                    background: #f8fafc;
                }

            .dash-table tbody td {
                padding: .85rem 1.5rem;
                font-size: .855rem;
                color: #334155;
                vertical-align: middle;
            }

        .tour-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #eff6ff;
            display: grid;
            place-items: center;
            color: #2563eb;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .tour-thumb {
            width: 40px;
            height: 34px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid #e2e8f0;
        }

        .cell-name {
            font-weight: 600;
            color: #0f172a;
        }

        .cell-sub {
            font-size: .72rem;
            color: #94a3b8;
            margin-top: 2px;
        }

        .badge-sm {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: .72rem;
            font-weight: 600;
            padding: .25rem .65rem;
            border-radius: 20px;
            white-space: nowrap;
        }

        .badge-approved {
            background: #dcfce7;
            color: #15803d;
        }

        .badge-pending {
            background: #fef9c3;
            color: #a16207;
        }

        .badge-rejected {
            background: #fee2e2;
            color: #b91c1c;
        }

        .review-list {
            padding: 1.25rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .review-item {
            display: flex;
            flex-direction: column;
            gap: .6rem;
        }

        .review-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: .6rem;
        }

        .rev-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-weight: 700;
            font-size: .8rem;
            color: #fff;
            flex-shrink: 0;
            overflow: hidden;
            background: #e2e8f0;
        }

            .rev-avatar.placeholder {
                background: linear-gradient(135deg, #2563eb, #7c3aed);
            }

        .rev-name {
            font-size: .855rem;
            font-weight: 700;
            color: #0f172a;
        }

        .rev-stars {
            font-size: 13px;
            color: #f59e0b;
            line-height: 1;
        }

            .rev-stars .empty {
                color: #e2e8f0;
            }

        .rev-time {
            font-size: .7rem;
            font-weight: 500;
            color: #94a3b8;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .rev-text {
            font-size: .82rem;
            color: #475569;
            line-height: 1.6;
            font-style: italic;
        }

        .rev-tour {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: .72rem;
            font-weight: 600;
            color: #2563eb;
        }

        .rev-divider {
            border: none;
            border-top: 1px solid #f1f5f9;
            margin: 0;
        }

        .view-all-btn {
            display: block;
            width: 100%;
            text-align: center;
            padding: .85rem;
            background: #f8fafc;
            font-size: .855rem;
            font-weight: 700;
            color: #475569;
            text-decoration: none;
            border-top: 1px solid #f1f5f9;
            transition: color .15s;
        }

            .view-all-btn:hover {
                color: #2563eb;
            }

        .empty-row td {
            text-align: center;
            padding: 2.5rem;
            color: #94a3b8;
            font-size: .855rem;
        }
    </style>
}

<div>
    <h1 class="dash-title">Dashboard Overview</h1>
    <p class="dash-sub">Tur platformunuzdaki son aktivitelerin özeti.</p>
</div>

<div class="dash-grid">
    <div class="col-left">

        <!-- Son Eklenen Turlar -->
        <div class="panel">
            <div class="panel-header">
                <h2>Son Eklenen Turlar</h2>
                <a asp-controller="AdminTour" asp-action="TourList">Tümünü Gör</a>
            </div>
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Tur Adı</th>
                        <th>Tarih</th>
                        <th>Fiyat</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentTours.Any())
                    {
                        <tr class="empty-row"><td colspan="3">Henüz tur eklenmemiş.</td></tr>
                    }
                    else
                    {
                        @foreach (var t in Model.RecentTours)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(t.ImageUrl))
                                        {
                                            <img src="@t.ImageUrl" class="tour-thumb" alt="@t.Title" />
                                        }
                                        else
                                        {
                                            <div class="tour-icon"><i class="bi bi-map"></i></div>
                                        }
                                        <div>
                                            <div class="cell-name">@t.Title</div>
                                            <div class="cell-sub">@t.City, @t.Country</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:#64748b;">@t.StartDate.ToString("dd MMM yyyy")</td>
                                <td><strong>@t.Price.ToString("N0") ₺</strong></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Son Rezervasyonlar -->
        <div class="panel">
            <div class="panel-header">
                <h2>Son Rezervasyonlar</h2>
                <a asp-controller="AdminBooking" asp-action="BookingList">Detaylar</a>
            </div>
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Müşteri</th>
                        <th>Tur</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentBookings.Any())
                    {
                        <tr class="empty-row"><td colspan="4">Henüz rezervasyon yapılmamış.</td></tr>
                    }
                    else
                    {
                        @foreach (var b in Model.RecentBookings)
                        {
                            <tr>
                                <td>
                                    <div class="cell-name">@b.FirstName @b.LastName</div>
                                    <div class="cell-sub">@b.Email</div>
                                </td>
                                <td>
                                    <div>@b.TourTitle</div>
                                    <div class="cell-sub">@b.PersonCount kişi</div>
                                </td>
                                <td><strong>@b.TotalPrice.ToString("N0") ₺</strong></td>
                                <td>
                                    @if (b.Status == "Onaylandı")
                                    {
                                        <span class="badge-sm badge-approved"><i class="bi bi-check-circle-fill"></i> Onaylandı</span>
                                    }
                                    else if (b.Status == "Reddedildi")
                                    {
                                        <span class="badge-sm badge-rejected"><i class="bi bi-x-circle-fill"></i> Reddedildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge-sm badge-pending"><i class="bi bi-clock-fill"></i> Beklemede</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- Sağ Kolon - Yorumlar -->
    <div class="col-right">
        <div class="panel" style="display:flex; flex-direction:column;">
            <div class="panel-header">
                <h2>Son Yorumlar</h2>
            </div>

            @if (!Model.RecentComments.Any())
            {
                <div style="padding:2.5rem; text-align:center; color:#94a3b8; font-size:.855rem;">
                    Henüz yorum yapılmamış.
                </div>
            }
            else
            {
                <div class="review-list">
                    @for (int idx = 0; idx < Model.RecentComments.Count; idx++)
                    {
                        var c = Model.RecentComments[idx];
                        <div class="review-item">
                            <div class="review-top">
                                <div class="reviewer-info">
                                    @if (!string.IsNullOrEmpty(c.ImageUrl))
                                    {
                                        <div class="rev-avatar">
                                            <img src="@c.ImageUrl" style="width:100%;height:100%;object-fit:cover;" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rev-avatar placeholder">
                                            @(string.IsNullOrEmpty(c.NameSurname) ? "?" : c.NameSurname.Substring(0, 1).ToUpper())
                                        </div>
                                    }
                                    <div>
                                        <div class="rev-name">@c.NameSurname</div>
                                        <div class="rev-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="@(i <= c.Score ? "" : "empty")">★</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <span class="rev-time">@c.CommentDate.ToString("dd MMM")</span>
                            </div>
                            <div class="rev-text">"@c.CommentDetail"</div>
                            <div class="rev-tour">
                                <i class="bi bi-geo-alt-fill" style="font-size:10px;"></i>
                                @c.Headline
                            </div>
                        </div>
                        @if (idx < Model.RecentComments.Count - 1)
                        {
                            <hr class="rev-divider" />
                        }
                    }
                </div>
            }

            <a asp-controller="AdminComment" asp-action="CommentList" class="view-all-btn">
                Tüm Yorumları Gör
            </a>
        </div>
    </div>

</div>

@section Scripts {
}
