@model List<Project3Travelin.Dtos.BookingDtos.ResultBookingDto>
@{
    ViewData["Title"] = "Rezervasyonlar";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 1.6rem;
            font-weight: 800;
            color: #1a202c;
            letter-spacing: -.03em;
            line-height: 1;
        }

        .breadcrumb {
            margin: 0;
            padding: 0;
            background: none;
        }

        .breadcrumb-item {
            font-size: .8rem;
        }

            .breadcrumb-item a {
                color: #2563eb;
                text-decoration: none;
            }

            .breadcrumb-item.active {
                color: #718096;
            }

        .table-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .table-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid #e2e8f0;
            flex-wrap: wrap;
            gap: .75rem;
        }

            .table-card-header .title {
                font-weight: 700;
                font-size: .95rem;
                color: #1a202c;
                display: flex;
                align-items: center;
                gap: .5rem;
            }

        .booking-count {
            background: #eff6ff;
            color: #2563eb;
            font-size: .72rem;
            font-weight: 600;
            padding: .2rem .6rem;
            border-radius: 20px;
        }

        .bookings-table {
            width: 100%;
            border-collapse: collapse;
        }

            .bookings-table thead th {
                background: #f8fafc;
                font-size: .72rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .06em;
                color: #718096;
                padding: .85rem 1rem;
                border-bottom: 1px solid #e2e8f0;
                white-space: nowrap;
            }

            .bookings-table tbody tr {
                transition: background .12s;
                border-bottom: 1px solid #f0f4f8;
            }

                .bookings-table tbody tr:last-child {
                    border-bottom: none;
                }

                .bookings-table tbody tr:hover {
                    background: #f8fafc;
                }

            .bookings-table tbody td {
                padding: .85rem 1rem;
                vertical-align: middle;
                font-size: .875rem;
                color: #2d3748;
            }

        .tour-thumb {
            width: 54px;
            height: 44px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #e2e8f0;
            display: block;
        }

        .tour-title-cell {
            font-weight: 600;
            color: #1a202c;
            font-size: .875rem;
        }

        .tour-id-cell {
            font-size: .72rem;
            color: #a0aec0;
            font-family: monospace;
        }

        .customer-name {
            font-weight: 600;
            color: #1a202c;
            font-size: .875rem;
        }

        .customer-email {
            font-size: .78rem;
            color: #718096;
        }

        .date-range {
            font-size: .82rem;
            font-weight: 500;
            white-space: nowrap;
        }

        .booking-date {
            font-size: .75rem;
            color: #a0aec0;
        }

        .price-cell {
            font-weight: 600;
            color: #1a202c;
            white-space: nowrap;
        }

        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .75rem;
            font-weight: 600;
            padding: .3rem .75rem;
            border-radius: 20px;
            white-space: nowrap;
        }

        .badge-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .badge-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .action-group {
            display: flex;
            align-items: center;
            gap: .35rem;
        }

        .btn-action {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: grid;
            place-items: center;
            border: none;
            cursor: pointer;
            font-size: .85rem;
            transition: all .15s;
        }

        .btn-approve {
            background: #d1fae5;
            color: #065f46;
        }

            .btn-approve:hover {
                background: #a7f3d0;
                color: #064e3b;
            }

        .btn-reject {
            background: #fee2e2;
            color: #991b1b;
        }

            .btn-reject:hover {
                background: #fecaca;
                color: #7f1d1d;
            }

        .empty-state {
            padding: 4rem 2rem;
            text-align: center;
            color: #a0aec0;
        }

            .empty-state i {
                font-size: 3rem;
                margin-bottom: 1rem;
                display: block;
            }

            .empty-state p {
                font-size: .9rem;
            }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Rezervasyon Listesi</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rezervasyonlar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <div class="title">
            <i class="bi bi-calendar-check" style="color:#a0aec0;"></i>
            Gelen Rezervasyonlar
            <span class="booking-count">@(Model?.Count ?? 0) kayıt</span>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <p>Henüz rezervasyon bulunmuyor.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="bookings-table">
                <thead>
                    <tr>
                        <th>Tur</th>
                        <th>Müşteri</th>
                        <th>Tarih Aralığı</th>
                        <th>Kişi</th>
                        <th>Toplam Fiyat</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(item.TourImageUrl))
                                    {
                                        <img src="@item.TourImageUrl" class="tour-thumb" alt="@item.TourTitle">
                                    }
                                    <div>
                                        <div class="tour-title-cell">@item.TourTitle</div>
                                        <div class="tour-id-cell">@item.BookingId</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="customer-name">@item.FirstName @item.LastName</div>
                                <div class="customer-email">@item.Email</div>
                            </td>
                            <td>
                                <div class="date-range">
                                    @item.StartDate.ToString("dd.MM.yyyy") – @item.EndDate.ToString("dd.MM.yyyy")
                                </div>
                                <div class="booking-date">Oluşturma: @item.BookingDate.ToString("dd.MM.yyyy")</div>
                            </td>
                            <td>@item.PersonCount</td>
                            <td><span class="price-cell">@item.TotalPrice.ToString("N2") TL</span></td>
                            <td>
                                @if (item.Status == "Onaylandı")
                                {
                                    <span class="badge-status badge-approved">
                                        <i class="bi bi-check-circle-fill"></i> Onaylandı
                                    </span>
                                }
                                else if (item.Status == "Reddedildi")
                                {
                                    <span class="badge-status badge-rejected">
                                        <i class="bi bi-x-circle-fill"></i> Reddedildi
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status badge-pending">
                                        <i class="bi bi-clock-fill"></i> Beklemede
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    <form asp-controller="AdminBooking" asp-action="ApproveBooking"
                                          asp-route-id="@item.BookingId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-approve" title="Onayla"
                                                onclick="return confirm('Bu rezervasyonu onaylayıp müşteriye mail göndermek istiyor musunuz?')">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-controller="AdminBooking" asp-action="RejectBooking"
                                          asp-route-id="@item.BookingId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-reject" title="Reddet"
                                                onclick="return confirm('Bu rezervasyonu reddetmek istiyor musunuz?')">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


