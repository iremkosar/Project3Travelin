<script src="/js/translations.js"></script>
<script>
    // Mevcut dili select'te göster
    (function () {
        var match = document.cookie.match(/\.AspNetCore\.Culture=c%3D([a-z]+)/);
        var current = match ? match[1] : 'tr';
        var sel = document.getElementById('langSelect');
        if (sel) {
            for (var i = 0; i < sel.options.length; i++) {
                if (sel.options[i].value === current) {
                    sel.selectedIndex = i;
                    break;
                }
            }
        }
    })();

    function submitLang() {
        // CSRF token'ı sayfadan al
        var token = document.querySelector('input[name="__RequestVerificationToken"]');
        if (token) {
            document.getElementById('langCsrf').value = token.value;
        }
        document.getElementById('langReturnUrl').value = window.location.pathname;
        document.getElementById('langForm').submit();
    }
</script>
