@using Project3Travelin.Dtos.TourDtos
@model List<ResultTourDto>

<!-- Popular Tours starts -->
<section class="trending">
    <div class="container">
        <div class="section-title mb-6 w-75 mx-auto text-center">
            <h4 class="mb-1 theme1">Popüler Turlar</h4>
            <h2 class="mb-1">Sizin İçin Seçtiğimiz <span class="theme">Özel Rotalar</span></h2>
            <p>
                En çok tercih edilen tur seçeneklerimizi inceleyin, hayalinizdeki seyahati
                avantajlı fırsatlarla keşfetmeye hemen başlayın.
            </p>
        </div>

        <div class="trend-box">
            <div class="row">
                <div class="col-lg-12">
                    <div class="row item-slider2 slick_arrows">
                        @foreach (var tour in Model)
                        {
                            <div class="col-lg-3 col-md-6">
                                <div class="trend-item rounded box-shadow border h-100 d-flex flex-column">

                                    <div class="trend-image position-relative m-2 rounded" style="height: 220px; overflow: hidden;">
                                        <img src="@tour.ImageUrl"
                                             alt="@tour.Title"
                                             style="width: 100%; height: 100%; object-fit: cover;" />
                                    </div>

                                    <div class="trend-content p-3 position-relative bg-white d-flex flex-column flex-grow-1">
                                        <h6 class="theme mb-1">
                                            <i class="flaticon-location-pin"></i> @tour.Country
                                        </h6>

                                        <h4 class="mb-2">
                                            <a asp-controller="Tour" asp-action="TourDetail" asp-route-id="@tour.TourId">
                                                @tour.Title
                                            </a>
                                        </h4>

                                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                                            <div class="rating-main d-inline-flex align-items-center gap-1 fs-7">
                                                <div class="rating">
                                                    <span class="fa fa-star checked theme1"></span>
                                                </div>
                                                <span>4.5</span>
                                            </div>

                                            <div class="px-2 py-1 rounded fs-7">
                                                <div class="entry-author">
                                                    <i class="icon-calendar theme1"></i>
                                                    <span>@tour.DayNight</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="entry-meta mt-auto">
                                            <div class="entry-author d-flex align-items-center justify-content-between fs-8">
                                                <p class="mb-0">
                                                    <span class="theme fw-bold fs-6">₺@tour.Price.ToString("N0")</span>
                                                    / kişi başı
                                                </p>

                                                <a asp-controller="Tour"
                                                   asp-action="TourDetail"
                                                   asp-route-id="@tour.TourId"
                                                   class="nir-btn py-1 px-3">
                                                    İncele
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Popular Tours ends -->