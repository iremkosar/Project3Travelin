<!-- Faq starts -->
<section class="faq-section">
    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">
                <div class="d-flex justify-content-end position-relative mb-5 mb-lg-0">
                    <img src="/travelin/images/santo1.jpg" alt="Tur Deneyimi" class="img-fluid rounded w-75 me-lg-4" />
                    <img src="/travelin/images/santo2.jpg" alt="Destinasyon Manzarası" class="img-fluid stacked-img" style="width: 200px" />
                </div>
            </div>

            <div class="col-lg-6">

                <div class="section-title mb-6">
                    <h5 class="mb-1 theme1">
                        <i class="icon-plane theme1 fs-7"></i> Sık Sorulan Sorular
                    </h5>
                    <h2 class="mb-1">
                        Seyahatinizle İlgili <span class="theme">Merak Edilenler</span>
                    </h2>
                </div>

                <div class="accordion faq-accordion" id="travelFaq">

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button" type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseOne"
                                    aria-expanded="true"
                                    aria-controls="collapseOne">

                                Seyahat için yanıma neler almalıyım?

                            </button>
                        </h2>

                        <div id="collapseOne"
                             class="accordion-collapse collapse show"
                             aria-labelledby="headingOne">

                            <div class="accordion-body">
                                Gideceğiniz destinasyonun iklim koşullarına uygun kıyafetler
                                hazırlamanızı öneririz. Pasaport, kimlik, uçak bileti,
                                rezervasyon belgeleri ve gerekli ise vize belgelerinizin
                                yanınızda olduğundan emin olun.
                            </div>

                        </div>
                    </div>


                    <div class="accordion-item">

                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseTwo"
                                    aria-expanded="false"
                                    aria-controls="collapseTwo">

                                Seyahat öncesinde bilmem gereken kurallar var mı?

                            </button>
                        </h2>

                        <div id="collapseTwo"
                             class="accordion-collapse collapse"
                             aria-labelledby="headingTwo">

                            <div class="accordion-body">
                                Gideceğiniz ülkenin güncel vize şartlarını, pasaport
                                geçerlilik süresini ve giriş koşullarını seyahat öncesinde
                                kontrol etmenizi öneririz.
                            </div>

                        </div>

                    </div>


                    <div class="accordion-item">

                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseThree"
                                    aria-expanded="false"
                                    aria-controls="collapseThree">

                                Rezervasyonumu nasıl değiştirebilir veya iptal edebilirim?

                            </button>
                        </h2>

                        <div id="collapseThree"
                             class="accordion-collapse collapse"
                             aria-labelledby="headingThree">

                            <div class="accordion-body">
                                Rezervasyon değişikliği veya iptal işlemlerinizi web
                                sitemiz üzerinden kolayca gerçekleştirebilir veya
                                müşteri destek ekibimizle iletişime geçerek yardım
                                alabilirsiniz.
                            </div>

                        </div>

                    </div>


                    <div class="accordion-item">

                        <h2 class="accordion-header" id="headingFour">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseFour"
                                    aria-expanded="false"
                                    aria-controls="collapseFour">

                                Turlarınızda hangi konaklama seçenekleri sunuluyor?

                            </button>
                        </h2>

                        <div id="collapseFour"
                             class="accordion-collapse collapse"
                             aria-labelledby="headingFour">

                            <div class="accordion-body">
                                Tur programına bağlı olarak otel, butik otel veya
                                tatil köyü gibi farklı konaklama seçenekleri
                                sunulmaktadır. Tüm konaklama tesisleri konfor
                                ve kalite standartlarına göre seçilmektedir.
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
</section>
<!-- Faq Ends -->