@{
    Layout = null;
    ViewData["Title"] = "Hakkımızda";
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="zxx">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Travelin - Hakkımızda</title>
    <link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png" />
    <link href="/travelin/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/travelin/css/style.css" rel="stylesheet" />
    <link href="/travelin/css/plugin.css" rel="stylesheet" />
    <link rel="stylesheet" href="/travelin/css/fontawesome.min.css" />
    <link rel="stylesheet" href="/travelin/fonts/line-icons.css" />
</head>
<body class="home-eight">

    <div id="preloader"><div id="status"></div></div>

    @await Html.PartialAsync("_AboutHeaderPartial")

    @* Banner - Partial (saf HTML) *@
    @await Html.PartialAsync("_AboutBannerPartial")

 
    @await Component.InvokeAsync("_AboutTopDestinationsComponentPartial")

    @* About Us - Partial (saf HTML) *@
    @await Html.PartialAsync("_AboutUsPartial")

    @* Popular Places - ViewComponent (DB'den veri çekiyor) *@
    @await Component.InvokeAsync("_AboutPopularPlacesComponentPartial")

    @* Discount Action - Partial (saf HTML) *@
    @await Html.PartialAsync("_AboutDiscountActionPartial")

    @* Why Choose Us - Partial (saf HTML) *@
    @await Html.PartialAsync("_AboutWhyChooseUsPartial")

    @* FAQ + Partners - Partial (saf HTML) *@
    @await Html.PartialAsync("_AboutFaqPartial")

    @* Footer - ViewComponent (farklı sayfalarda kullanılıyor) *@
    @await Html.PartialAsync("_AboutFooterPartial")

    <div id="back-to-top"><a href="#"></a></div>

    <!-- Search Modal -->
    <div id="search1">
        <button type="button" class="close">×</button>
        <form>
            <input type="search" value="" placeholder="type keyword(s) here" />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

    <!-- Login / Register Modal -->
    <div class="modal fade log-reg" id="exampleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="post-tabs">
                        <ul class="nav nav-tabs nav-pills nav-fill" id="postsTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" data-bs-target="#login" data-bs-toggle="tab" id="login-tab" role="tab" type="button">Login</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" data-bs-target="#register" data-bs-toggle="tab" id="register-tab" role="tab" type="button">Register</button>
                            </li>
                        </ul>
                        <div class="tab-content blog-full" id="postsTabContent">
                            <div class="tab-pane fade active show" id="login" role="tabpanel">
                                <div class="row">
                                    <div class="col-lg-6">
                                        <div class="blog-image rounded">
                                            <a href="#" style="background-image: url(/travelin/images/trending/trending5.jpg)"></a>
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <h4 class="text-center border-b pb-2">Login</h4>
                                        <form method="post" action="#">
                                            <div class="form-group mb-2">
                                                <input type="text" class="form-control" placeholder="User Name or Email Address" />
                                            </div>
                                            <div class="form-group mb-2">
                                                <input type="password" class="form-control" placeholder="Password" />
                                            </div>
                                            <div class="comment-btn mb-2 text-center border-b">
                                                <input type="submit" class="nir-btn w-100" value="Login" />
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="register" role="tabpanel">
                                <div class="row">
                                    <div class="col-lg-6">
                                        <div class="blog-image rounded">
                                            <a href="#" style="background-image: url(/travelin/images/trending/trending5.jpg)"></a>
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <h4 class="text-center border-b pb-2">Register</h4>
                                        <form method="post" action="#">
                                            <div class="form-group mb-2">
                                                <input type="text" class="form-control" placeholder="User Name" />
                                            </div>
                                            <div class="form-group mb-2">
                                                <input type="text" class="form-control" placeholder="Email Address" />
                                            </div>
                                            <div class="form-group mb-2">
                                                <input type="password" class="form-control" placeholder="Password" />
                                            </div>
                                            <div class="comment-btn mb-2 text-center border-b">
                                                <input type="submit" class="nir-btn w-100" value="Register" />
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/travelin/js/jquery-3.5.1.min.js"></script>
    <script src="/travelin/js/bootstrap.min.js"></script>
    <script src="/travelin/js/fontawesome.min.js"></script>
    <script src="/travelin/js/plugin.js"></script>
    <script src="/travelin/js/main.js"></script>
    <script src="/travelin/js/custom-swiper2.js"></script>
    <script src="/travelin/js/custom-nav.js"></script>

</body>
</html>
