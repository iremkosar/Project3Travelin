@model Project3Travelin.ViewModels.BookingViewModel

@{
    Layout = null;
    ViewData["Title"] = "Rezervasyon Yap - " + Model.Tour.Title;
}

<!DOCTYPE html>
@await Component.InvokeAsync("_TourHeadComponentPartial")

<!-- header starts -->
<header class="main_header_area">
    <div class="header-content py-1 bg-theme">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="links">
                <ul>
                    <li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
                    <li><a href="#" class="white"><i class="icon-location-pin white"></i> İstanbul, Türkiye</a></li>
                    <li><a href="#" class="white"><i class="icon-clock white"></i> Pzrt-Cts: 08.30-18.00</a></li>
                </ul>
            </div>
            <div class="links float-right">
                <ul>
                    <li><a href="#" class="white"><i class="fab fa-facebook"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-twitter"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-instagram"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-linkedin"></i></a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="header_menu" id="header_menu">
        <nav class="navbar navbar-default">
            <div class="container">
                <div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
                    <div class="navbar-header">
                        <a class="navbar-brand" href="#">
                            <img src="/travelin/images/logo.png" alt="image">
                        </a>
                    </div>
                    <div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
                        <ul class="nav navbar-nav" id="responsive-menu">
                            <li><a href="#">Ana Sayfa</a></li>
                            <li><a asp-controller="Tour" asp-action="TourList">Tur Listesi</a></li>
                            <li class="search-main"><a href="#search1" class="mt_search"><i class="fa fa-search"></i></a></li>
                        </ul>
                    </div>
                    <div class="register-login d-flex align-items-center">
                        <a href="#" class="me-3"><i class="icon-user"></i> Giriş Yap / Kayıt Ol</a>
                        <a asp-controller="Tour" asp-action="TourList" class="nir-btn white">Tur Listesi</a>
                    </div>
                    <div id="slicknav-mobile"></div>
                </div>
            </div>
        </nav>
    </div>
</header>

<!-- BreadCrumb -->
<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/images/bg/bg1.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">Rezervasyon Yap</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#">Anasayfa</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Tour" asp-action="TourList">Turlar</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Rezervasyon</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<!-- Main Content -->
<section class="trending pt-6 pb-6 bg-lgrey">
    <div class="container">
        <form asp-controller="Booking" asp-action="CreateBooking" method="post">
            <input type="hidden" name="TourId" value="@Model.Tour.TourId" />
            <input type="hidden" name="TourTitle" value="@Model.Tour.Title" />
            <input type="hidden" name="TourImageUrl" value="@Model.Tour.ImageUrl" />
            <input type="hidden" name="TotalPrice" id="hiddenTotalPrice" value="@Model.Tour.Price" />

            <div class="row">
                <!-- Sol: Form -->
                <div class="col-lg-8 mb-4">
                    <div class="bg-white rounded box-shadow p-4">

                        <div class="row">
                            <!-- Ünvan + Ad + Soyad -->
                           
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ad</label>
                                <input type="text" name="FirstName" class="form-control" placeholder="Adınız" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Soyad</label>
                                <input type="text" name="LastName" class="form-control" placeholder="Soyadınız" required>
                            </div>

                            <!-- E-posta + Telefon -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">E-posta</label>
                                <input type="email" name="Email" class="form-control" placeholder="E-posta Adresiniz" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Telefon</label>
                                <input type="text" name="Phone" class="form-control" placeholder="Telefon No." required>
                            </div>

                            <!-- Cinsiyet + Doğum Tarihi -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cinsiyet</label>
                                <select name="Gender" class="form-select">
                                    <option value="">Cinsiyet Seçin</option>
                                    <option value="Erkek">Erkek</option>
                                    <option value="Kadın">Kadın</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Doğum Tarihi</label>
                                <input type="date" name="BirthDate" class="form-control">
                            </div>

                            <!-- Ülke Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ülke</label>
                                <select name="Country" id="countrySelect" class="form-select" onchange="updateCities()">
                                    <option value="">Ülke Seçin</option>
                                    <option value="Türkiye">Türkiye</option>
                                    <option value="Almanya">Almanya</option>
                                    <option value="Amerika Birleşik Devletleri">Amerika Birleşik Devletleri</option>
                                    <option value="Avustralya">Avustralya</option>
                                    <option value="Avusturya">Avusturya</option>
                                    <option value="Belçika">Belçika</option>
                                    <option value="Fransa">Fransa</option>
                                    <option value="Hollanda">Hollanda</option>
                                    <option value="İngiltere">İngiltere</option>
                                    <option value="İspanya">İspanya</option>
                                    <option value="İsveç">İsveç</option>
                                    <option value="İsviçre">İsviçre</option>
                                    <option value="İtalya">İtalya</option>
                                    <option value="Japonya">Japonya</option>
                                    <option value="Kanada">Kanada</option>
                                    <option value="Norveç">Norveç</option>
                                    <option value="Polonya">Polonya</option>
                                    <option value="Portekiz">Portekiz</option>
                                    <option value="Rusya">Rusya</option>
                                    <option value="Yunanistan">Yunanistan</option>
                                    <option value="Diğer">Diğer</option>
                                </select>
                            </div>

                            <!-- Şehir Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Şehir</label>
                                <select name="City" id="citySelect" class="form-select">
                                    <option value="">Önce ülke seçin</option>
                                </select>
                            </div>

                            <!-- Adres -->
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Adres</label>
                                <input type="text" name="Address" class="form-control" placeholder="Adresiniz">
                            </div>
                        </div>

                        <!-- Tur Bilgileri -->
                        <div class="mb-4">
                            <h4 class="border-b pb-2 mb-3">Tur Bilgileri</h4>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Giriş Tarihi</label>
                                    <input type="date" name="CheckInDate" class="form-control"
                                           value="@Model.Tour.StartDate.ToString("yyyy-MM-dd")">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Çıkış Tarihi</label>
                                    <input type="date" name="CheckOutDate" class="form-control">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Kişi Sayısı</label>
                                    <input type="number" name="PersonCount" id="personCountInput"
                                           class="form-control" min="1" max="@Model.Tour.Capacity"
                                           value="1" onchange="updateTotal()" oninput="updateTotal()">
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Toplam Fiyat (Tur fiyatı x Kişi sayısı)</label>
                                    <input type="text" id="totalPriceDisplay" class="form-control bg-light"
                                           value="@Model.Tour.Price.ToString("N2")" readonly>
                                </div>
                            </div>
                        </div>

                        <!-- Onayla Butonu -->
                        <div class="d-grid mt-2">
                            <button type="submit"
                                    style="background-color:#0aab97; border:none; color:white; border-radius:8px; font-size:16px; padding:16px; width:100%; cursor:pointer;">
                                ✓ &nbsp; Rezervasyonu Tamamla
                            </button>
                        </div>

                    </div>
                </div>

                <!-- Sağ: Özet -->
                <div class="col-lg-4 mb-4">
                    <div class="sidebar-sticky">

                        <!-- Tur Kartı -->
                        <div class="bg-white rounded box-shadow p-3 mb-4">
                            <div class="d-flex align-items-center">
                                <img src="@Model.Tour.ImageUrl" alt="@Model.Tour.Title"
                                     style="width:90px; height:70px; object-fit:cover; border-radius:8px; flex-shrink:0;" class="me-3">
                                <div>
                                    <h6 class="mb-1 fw-bold">@Model.Tour.Title</h6>
                                    <p class="mb-1 theme" style="font-size:13px;"><i class="icon-location-pin"></i> @Model.Tour.Country</p>
                                    <small class="d-block"><strong>Fiyat:</strong> @Model.Tour.Price.ToString("N0") TL</small>
                                    <small class="d-block"><strong>Süre:</strong> @Model.Tour.DayNight</small>
                                </div>
                            </div>
                        </div>

                        <!-- Bilgi Kutusu -->
                        <div class="bg-white rounded box-shadow p-3 mb-4">
                            <div class="d-flex align-items-start">
                                <div class="me-3 d-flex align-items-center justify-content-center"
                                     style="background-color:#0aab97; border-radius:8px; min-width:48px; height:48px;">
                                    <i class="fa fa-info text-white"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold">Bilgi:</h6>
                                    <small>Rezervasyonunuz onaylandıktan sonra e-posta ile bilgilendirileceksiniz.</small>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

<!-- footer -->
<footer class="pt-10 pb-4" style="background-image: url(/travelin/images/background_pattern.png);">
    <div class="section-shape top-0" style="background-image: url(/travelin/images/shape8.png);"></div>
    <div class="footer-copyright mt-4">
        <div class="container">
            <div class="copyright-inner rounded p-3 d-md-flex align-items-center justify-content-between">
                <div class="copyright-text">
                    <p class="m-0 white">2022 Travelin. All rights reserved.</p>
                </div>
                <div class="social-links">
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                        <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div id="particles-js"></div>
</footer>

<div id="back-to-top"><a href="#"></a></div>

<script src="/travelin/js/jquery-3.5.1.min.js"></script>
<script src="/travelin/js/bootstrap.min.js"></script>
<script src="/travelin/js/fontawesome.min.js"></script>
<script src="/travelin/js/particles.js"></script>
<script src="/travelin/js/particlerun.js"></script>
@* <script src="/travelin/js/plugin.js"></script> *@
<script src="/travelin/js/main.js"></script>
<script src="/travelin/js/custom-nav.js"></script>

<script>
    var basePrice = @Model.Tour.Price;

    // Ülkeye göre şehirler
    var citiesByCountry = {
        "Türkiye": ["Adana","Adıyaman","Afyonkarahisar","Ağrı","Amasya","Ankara","Antalya","Artvin","Aydın","Balıkesir","Bilecik","Bingöl","Bitlis","Bolu","Burdur","Bursa","Çanakkale","Çankırı","Çorum","Denizli","Diyarbakır","Edirne","Elazığ","Erzincan","Erzurum","Eskişehir","Gaziantep","Giresun","Gümüşhane","Hakkari","Hatay","Isparta","İçel","İstanbul","İzmir","Kars","Kastamonu","Kayseri","Kırklareli","Kırşehir","Kocaeli","Konya","Kütahya","Malatya","Manisa","Maraş","Mardin","Muğla","Muş","Nevşehir","Niğde","Ordu","Rize","Sakarya","Samsun","Siirt","Sinop","Sivas","Tekirdağ","Tokat","Trabzon","Tunceli","Şanlıurfa","Uşak","Van","Yozgat","Zonguldak","Aksaray","Bayburt","Karaman","Kırıkkale","Batman","Şırnak","Bartın","Ardahan","Iğdır","Yalova","Karabük","Kilis","Osmaniye","Düzce"],
        "Almanya": ["Berlin","Hamburg","Münih","Köln","Frankfurt","Stuttgart","Düsseldorf","Dortmund","Essen","Leipzig"],
        "Amerika Birleşik Devletleri": ["New York","Los Angeles","Chicago","Houston","Phoenix","Philadelphia","San Antonio","San Diego","Dallas","San Jose"],
        "Fransa": ["Paris","Marsilya","Lyon","Toulouse","Nice","Nantes","Strasbourg","Montpellier","Bordeaux","Lille"],
        "İngiltere": ["Londra","Birmingham","Leeds","Glasgow","Sheffield","Bradford","Edinburgh","Liverpool","Manchester","Bristol"],
        "İtalya": ["Roma","Milano","Napoli","Torino","Palermo","Cenova","Bologna","Floransa","Bari","Katanya"],
        "İspanya": ["Madrid","Barselona","Valencia","Sevilla","Zaragoza","Malaga","Murcia","Palma","Las Palmas","Bilbao"],
        "Diğer": ["Diğer"]
    };

    function updateCities() {
        var country = document.getElementById('countrySelect').value;
        var citySelect = document.getElementById('citySelect');
        citySelect.innerHTML = '<option value="">Şehir Seçin</option>';

        if (country && citiesByCountry[country]) {
            citiesByCountry[country].forEach(function(city) {
                var opt = document.createElement('option');
                opt.value = city;
                opt.textContent = city;
                citySelect.appendChild(opt);
            });
        } else if (country) {
            // Listede olmayan ülkeler için genel seçenek
            var opt = document.createElement('option');
            opt.value = "Diğer";
            opt.textContent = "Diğer";
            citySelect.appendChild(opt);
        } else {
            citySelect.innerHTML = '<option value="">Önce ülke seçin</option>';
        }
    }

    function updateTotal() {
        var count = parseInt(document.getElementById('personCountInput').value) || 1;
        var total = basePrice * count;
        document.getElementById('totalPriceDisplay').value =
            total.toLocaleString('tr-TR', { minimumFractionDigits: 2 });
        document.getElementById('hiddenTotalPrice').value = total;
    }

    updateTotal();
</script>
