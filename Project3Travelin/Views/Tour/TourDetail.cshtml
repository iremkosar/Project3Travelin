<script>
    async function generateRoute() {
        const btn = document.getElementById('routeBtn');
        const loading = document.getElementById('routeLoading');
        const result = document.getElementById('routeResult');

        btn.style.display = 'none';
        loading.style.display = 'block';
        result.style.display = 'none';

        try {
            const response = await fetch('/Tour/GenerateRoute', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tourName: '@Html.Raw(Model.Tour.Title)',
                    city: '@Html.Raw(Model.Tour.City)',
                    country: '@Html.Raw(Model.Tour.Country)'
                })
            });

            const data = await response.json();
            console.log('Gelen data:', JSON.stringify(data));

            loading.style.display = 'none';
            result.style.display = 'block';

            if (data.error) {
                result.innerHTML = '<div class="alert alert-danger">' + data.error + '</div>';
            } else {
                result.innerHTML = data.route;
            }

        } catch (e) {
            loading.style.display = 'none';
            btn.style.display = 'block';
            alert('Bir hata oluştu, tekrar deneyin.');
        }
    }
</script>






