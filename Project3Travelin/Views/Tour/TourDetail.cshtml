<!-- top Destination starts -->
<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="single-content">
                    <div id="highlight">
                        <div class="single-full-title border-b mb-2 pb-2">
                            <div class="single-title">
                                <h2 class="mb-1">@Model.Tour.Title</h2>
                                <div class="rating-main d-md-flex align-items-center">
                                    <p class="mb-0 me-2">
                                        <i class="icon-location-pin"></i>
                                        @Model.Tour.City, @Model.Tour.Country
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="description-images mb-4">
                            <img src="@Model.Tour.ImageUrl" alt="@Model.Tour.Title" class="w-100 rounded">
                        </div>

                        <div class="description mb-2">
                            <h4>Açıklama</h4>
                            <p>@Model.Tour.Description</p>
                        </div>

                        <div class="tour-includes mb-4">
                            <table>
                                <tbody>
                                    <tr>
                                        <td><i class="fa fa-clock-o pink mr-1" aria-hidden="true"></i> @Model.Tour.DayNight</td>
                                        <td><i class="fa fa-group pink mr-1" aria-hidden="true"></i> Max: @Model.Tour.Capacity kişi</td>
                                        <td><i class="fa fa-calendar pink mr-1" aria-hidden="true"></i> @Model.Tour.StartDate.ToString("dd MMM yyyy") - @Model.Tour.EndDate.ToString("dd MMM yyyy")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        @if (Model.Tour.Stops != null && Model.Tour.Stops.Any())
                        {
                            <div id="iternary" class="accrodion-grp faq-accrodion mb-4" data-grp-name="faq-accrodion">
                                @foreach (var stop in Model.Tour.Stops)
                                {
                                    <div class="accrodion">
                                        <div class="accrodion-title rounded">
                                            <h5 class="mb-0">
                                                <span>Gün @stop.DayNumber</span> - @stop.StopTitle
                                            </h5>
                                        </div>
                                        <div class="accrodion-content" style="display:none;">
                                            <div class="inner">
                                                <p>@stop.StopDescription</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Tour.SecondImageUrl))
                    {
                        <div class="description-images mb-4">
                            <img src="@Model.Tour.SecondImageUrl" alt="@Model.Tour.Title" class="w-100 rounded">
                        </div>
                    }

                    <!-- AI Rota Kartı -->
                    <div class="bg-white rounded box-shadow p-4 mb-4">
                        <h4 class="mb-3"><i class="fa fa-map-marked-alt theme me-2"></i> 4 Günlük Gezi Rotası</h4>
                        <p class="text-muted" style="font-size:14px;">Yapay zeka destekli rota planlayıcı ile <strong>@Model.Tour.Title</strong> için önerilen gezi rotanızı oluşturun.</p>

                        <button onclick="generateRoute()" id="routeBtn" class="nir-btn w-100 mb-3">
                            <i class="fa fa-magic me-2"></i> Rota Oluştur
                        </button>

                        <div id="routeLoading" style="display:none; text-align:center; padding:20px;">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Rota oluşturuluyor...</p>
                        </div>

                        <div id="routeResult" style="display:none;"></div>
                    </div>

                    <!-- YORUMLAR ViewComponent -->
                    @await Component.InvokeAsync("CommentList",
                             new { comments = Model.Comments })

                    <!-- YORUM FORMU ViewComponent -->
                    @await Component.InvokeAsync("AddCommentForm",
                             new { tourId = Model.Tour.TourId })

                </div>
            </div>

            <div class="col-lg-4 ps-lg-4">
                <div class="sidebar-sticky sticky1">
                  -
                    <div class="desc-box bg-dark p-4 rounded box-shadow mb-4" style="background-color:#1a2332 !important;">
                        <h4 class="mb-3 text-white text-center">Rezervasyon Yap</h4>
                        <hr style="border-color: rgba(255,255,255,0.2);">

                        <p class="text-white-50 mb-1">Seçtiğiniz tarih</p>
                        <p class="text-white mb-1">
                            <i class="fa fa-calendar me-2"></i>
                            <strong>@Model.Tour.StartDate.ToString("d MMMM yyyy")</strong>
                        </p>
                        <p class="text-white-50 mb-3">
                            (@Model.Tour.DayNight)
                            <a href="#" class="text-info ms-2">Değiştir</a>
                        </p>

                        <label class="text-white mb-1">Kişi Sayısı</label>
                        <select id="personCount" class="form-select mb-3" onchange="updatePrice()">
                            @for (int i = 1; i <= Model.Tour.Capacity; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>

                        <div class="price-summary mb-3">
                            <div class="d-flex justify-content-between text-white-50 mb-1">
                                <span id="priceLabel">@Model.Tour.Price.ToString("N2") ₺ x 1</span>
                                <span id="priceTotal" class="text-white">@Model.Tour.Price.ToString("N2") ₺</span>
                            </div>
                            <div class="d-flex justify-content-between text-white-50 mb-2">
                                <span>Other fees</span>
                                <span class="text-success">Free</span>
                            </div>
                            <hr style="border-color: rgba(255,255,255,0.2);">
                            <div class="d-flex justify-content-between">
                                <strong class="text-white">Total</strong>
                                <strong class="text-white" id="totalPrice">@Model.Tour.Price.ToString("N2") ₺</strong>
                            </div>
                        </div>

                        <a asp-controller="Booking" asp-action="CreateBooking" asp-route-tourId="@Model.Tour.TourId"
                           class="nir-btn w-100 text-center d-block">
                            Rezervasyon Yap
                        </a>
                    </div>

                    <script>
                        var basePrice = @Model.Tour.Price;
                        function updatePrice() {
                            var count = parseInt(document.getElementById('personCount').value);
                            var total = basePrice * count;
                            document.getElementById('priceLabel').textContent =
                                basePrice.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺ x ' + count;
                            document.getElementById('priceTotal').textContent =
                                total.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
                            document.getElementById('totalPrice').textContent =
                                total.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺';
                        }
                    </script>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- top Destination ends -->
