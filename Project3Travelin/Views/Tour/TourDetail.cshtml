<style>
    .star-rating {
        display: inline-flex;
        flex-direction: row-reverse;
        gap: 8px;
        font-size: 24px;
        line-height: 1;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            cursor: pointer;
            color: #d1d5db;
